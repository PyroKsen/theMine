{
  "name": "themine",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm -w server run dev\" \"npm -w client run dev\"",
    "dev:client": "npm -w client run dev",
    "dev:server": "npm -w server run dev",
    "build": "npm -w client run build",
    "start": "npm -w server run start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
